{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nightforge.dev/schemas/ticket.schema.json",
  "title": "NightForge Ticket",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "rfc_id", "title", "repository", "base_ref", "task_type", "acceptance", "budget", "deadline"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "id": {"type": "string", "pattern": "^DEV-[0-9]+$"},
    "rfc_id": {"type": "string", "pattern": "^RFC-[0-9]+$"},
    "title": {"type": "string", "minLength": 5},
    "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
    "base_ref": {"type": "string", "minLength": 1},
    "task_type": {"enum": ["test", "ci-repair", "documentation"]},
    "acceptance": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "budget": {"type": "object", "required": ["agent_minutes", "max_cost_usd"], "properties": {"agent_minutes": {"type": "integer", "minimum": 1}, "max_cost_usd": {"type": "number", "minimum": 0}}, "additionalProperties": false},
    "deadline": {"type": "string", "format": "date-time"}
  }
}
