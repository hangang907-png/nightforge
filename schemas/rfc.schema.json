{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nightforge.dev/schemas/rfc.schema.json",
  "title": "NightForge RFC",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "proposer", "problem", "evidence", "expected_impact", "scope", "budget", "acceptance", "rollback", "conflicts"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "id": {"type": "string", "pattern": "^RFC-[0-9]+$"},
    "title": {"type": "string", "minLength": 8, "maxLength": 160},
    "proposer": {"type": "string", "minLength": 1},
    "problem": {"type": "string", "minLength": 20},
    "evidence": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["uri", "sha256"], "properties": {"uri": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}, "additionalProperties": false}},
    "expected_impact": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "number"}},
    "scope": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "budget": {"type": "object", "required": ["agent_minutes", "max_cost_usd"], "properties": {"agent_minutes": {"type": "integer", "minimum": 1}, "max_cost_usd": {"type": "number", "minimum": 0}}, "additionalProperties": false},
    "acceptance": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
    "rollback": {"type": "string", "minLength": 5},
    "conflicts": {"type": "array", "items": {"type": "string"}}
  }
}
